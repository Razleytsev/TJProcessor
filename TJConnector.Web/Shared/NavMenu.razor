@using Microsoft.AspNetCore.Components.Authorization

@* Sidebar adopted from the Changer reference: single dark surface,
   rounded nav items, accent left-bar on the active route. The foot now
   pins the current user (avatar + name + Logout) above the version tag,
   matching the Calm Ops .co-sidebar-foot pattern. Test-Run link is
   admin-only (same pattern as Changer's Settings link). *@

<div class="sidebar">
    <a href="/" class="brand" aria-label="TJConnector — go to home">
        <img src="brand/logo-lockup-sidebar.svg" alt="TJConnector" class="brand-lockup" />
    </a>

    <nav class="nav-scrollable">
        <NavLink class="nav-link" href="batches">
            Order Batches
        </NavLink>
        <NavLink class="nav-link" href="containers">
            Submission Requests
        </NavLink>
        <NavLink class="nav-link" href="products">
            Products
        </NavLink>
        <AuthorizeView Roles="Admin">
            <NavLink class="nav-link" href="test-run">
                Test Run
            </NavLink>
            <NavLink class="nav-link" href="settings">
                Settings
            </NavLink>
        </AuthorizeView>
    </nav>

    @* Calm Ops sidebar foot: the deployment-contour tag on its own row ABOVE
       the version + current user + Logout row, all pinned to the bottom of the
       fixed sidebar. (Moved here from the old top-bar in MainLayout.) *@
    <div class="nav-footer">
        <span class="co-env-tag">Production-Test Contour</span>
        <div class="nav-footer-row">
            <span class="version-tag">v0.1</span>
            <AuthorizeView>
                <Authorized>
                    <span class="user-avatar">@Initials(context.User.Identity?.Name)</span>
                    <span class="user-name" title="@context.User.Identity?.Name">@context.User.Identity?.Name</span>
                    <a href="/logout" class="logout-link" onclick="return confirm('Sign out?');">Logout</a>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    // Two-letter initials for the avatar (e.g. "operator.k" -> "OK").
    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(new[] { ' ', '.', '_', '-' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpperInvariant();
        var t = name.Trim();
        return t.Substring(0, Math.Min(2, t.Length)).ToUpperInvariant();
    }
}
