@typeparam TItem

<input id="filter" @bind="FilterText" @bind:event="oninput" placeholder="Filter" />

<div class="table-wrapper">
    <table class="table">
        <thead>
            <tr>
                @foreach (var column in Columns)
                {
                    <th @onclick="() => SortBy(column)">
                        @column.Header
                        @if (SortColumn == column)
                        {
                            <span>@(SortAscending ? "▲" : "▼")</span>
                        }
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in FilteredItems)
            {
                <tr @onclick="() => OnRowClick.InvokeAsync(item)">
                    @foreach (var column in Columns)
                    {
                        <td>@column.Value(item)</td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public IEnumerable<TItem> Items { get; set; } = Enumerable.Empty<TItem>();

    [Parameter]
    public List<ColumnDefinition<TItem>> Columns { get; set; } = new();

    [Parameter]
    public EventCallback<TItem> OnRowClick { get; set; }

    private string FilterText { get; set; } = string.Empty;
    private ColumnDefinition<TItem>? SortColumn { get; set; }
    private bool SortAscending { get; set; } = true;

    private IEnumerable<TItem> FilteredItems => Items
        .Where(item => Columns.Any(column => column.Value(item)?.ToString()?.Contains(FilterText, StringComparison.OrdinalIgnoreCase) == true))
        .OrderBy(item => SortColumn?.Value(item) ?? "")
        .ThenBy(item => SortColumn != null && !SortAscending ? "" : "");

    private void SortBy(ColumnDefinition<TItem> column)
    {
        if (SortColumn == column)
        {
            SortAscending = !SortAscending;
        }
        else
        {
            SortColumn = column;
            SortAscending = true;
        }
    }

    public class ColumnDefinition<T>
    {
        public string Header { get; set; } = string.Empty;
        public Func<T, object?> Value { get; set; } = _ => null;
    }
}