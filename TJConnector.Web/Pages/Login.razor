@page "/login"
@layout LoginLayout
@inject NavigationManager Navigation

<PageTitle>Sign in · TJConnector</PageTitle>

<div class="login-container">
    <div class="co-card login-card">
        <img src="brand/logo-lockup.svg" alt="TJConnector" class="brand-lockup-light" />
        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="co-alert co-alert-error">
                <p>Invalid username or password.</p>
            </div>
        }
        <form method="post" action="/api/login">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="co-field">
                <label for="login-username">Username</label>
                <input id="login-username" name="username" type="text" class="co-input" autocomplete="username" autofocus />
            </div>
            <div class="co-field">
                <label for="login-password">Password</label>
                <input id="login-password" name="password" type="password" class="co-input" autocomplete="current-password" />
            </div>
            <button type="submit" class="co-btn co-btn-primary co-btn-block">Sign In</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }
}
