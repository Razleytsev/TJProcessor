@page "/login"
@layout LoginLayout
@inject NavigationManager Navigation

<PageTitle>Sign in · Abdulla</PageTitle>

<div class="login-container">
    <div class="login-box">
        <h2>Abdulla Sign In</h2>
        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-error">
                <p>Invalid username or password.</p>
            </div>
        }
        <form method="post" action="/api/login">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="form-group">
                <label for="login-username">Username</label>
                <input id="login-username" name="username" type="text" class="form-control" autocomplete="username" autofocus />
            </div>
            <div class="form-group">
                <label for="login-password">Password</label>
                <input id="login-password" name="password" type="password" class="form-control" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn btn-primary btn-block mt-1">Sign In</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }
}
