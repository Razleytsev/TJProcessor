@page "/batches"
@using TJConnector.SharedLibrary.DTOs.Forms
@using TJConnector.SharedLibrary.Models
@using TJConnector.Postgres.Entities
@implements IAsyncDisposable
@inject IBatchServiceWeb BatchService
@inject IProductService ProductService
@inject IMetadataService MetadataService
@inject IJSRuntime JSRuntime

<!-- ── Toast container ──────────────────────────────────────── -->
<div class="toast-container">
    @foreach (var t in toasts)
    {
        <div class="toast @t.CssClass">@t.Message</div>
    }
</div>

<!-- ── Confirm dialog ────────────────────────────────────────── -->
@if (showConfirm)
{
    <div class="modal-overlay">
        <div class="confirm-box">
            <p class="mb-3">@confirmMessage</p>
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-sm btn-danger" @onclick="ConfirmYes">Yes, Cancel</button>
                <button class="btn btn-sm btn-secondary" @onclick="() => showConfirm = false">No</button>
            </div>
        </div>
    </div>
}

<!-- ── Page root ─────────────────────────────────────────────── -->
<div class="page-root-flex">

    <!-- Header -->
    <div class="page-header">
        <h5 class="mb-0">Order Batches</h5>
        <div class="d-flex align-items-center gap-2">
            @if (isRefreshing) { <span class="loading-spinner" title="Refreshing…"></span> }
            <span class="text-xs text-muted">↻ @refreshInterval s</span>
            <button class="btn btn-sm btn-primary" @onclick="ShowOrderCodesModal">+ Order Codes</button>
        </div>
    </div>

    <!-- Split pane -->
    <div class="split-pane-wrapper" id="batch-split-wrapper">

        <!-- ── TOP: batch list ───────────────────────────────── -->
        <div class="split-pane-top" style="flex: 0 0 @(topPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;">
            <div class="pane-toolbar">
                <span class="pane-title">Batches (@(batches?.Count() ?? 0))</span>
            </div>
            <div class="pane-scroll">
                @if (batches == null)
                {
                    <div class="loading-state">Loading batches…</div>
                }
                else if (!batches.Any())
                {
                    <div class="empty-state">No batches. Click "+ Order Codes" to create one.</div>
                }
                else
                {
                    <table class="table table-sm table-xs-font table-hover mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>ID</th>
                                <th>Type</th>
                                <th>GTIN</th>
                                <th>Count</th>
                                <th>Description</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in PagedBatches)
                            {
                                var (sc, sl) = BatchStatusInfo(b.Status);
                                <tr class="@(selectedBatch?.Id == b.Id ? "highlighted-row" : "")"
                                    style="cursor:pointer;" @onclick="() => SelectBatch(b)">
                                    <td>@b.Id</td>
                                    <td>@BatchTypeLabel(b.Type)</td>
                                    <td>@(b.Product?.Gtin ?? "—")</td>
                                    <td>@b.Count</td>
                                    <td>@b.Description</td>
                                    <td>@b.RecordDate.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                                    <td><span class="badge @sc">@sl</span></td>
                                    <td class="cell-actions" @onclick:stopPropagation="true">
                                        @if (b.Status == 0 || b.Status == 1)
                                        {
                                            <button class="btn-xs btn btn-outline-danger"
                                                    @onclick="() => PromptCancelBatch(b)">Cancel</button>
                                        }
                                        @if (b.Status == 2)
                                        {
                                            <button class="btn-xs btn btn-outline-success"
                                                    @onclick="() => DownloadBatch(b)">⬇</button>
                                        }
                                        @if (b.Status == -1)
                                        {
                                            <button class="btn-xs btn btn-outline-warning"
                                                    @onclick="() => ContinueBatch(b)">Continue</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (BatchTotalPages > 1)
                    {
                        <div class="pagination-bar">
                            <button class="pg-btn" disabled="@(batchPage <= 1)"
                                    @onclick="() => batchPage--">&#8249;</button>
                            <span class="pg-info">@batchPage / @BatchTotalPages</span>
                            <button class="pg-btn" disabled="@(batchPage >= BatchTotalPages)"
                                    @onclick="() => batchPage++">&#8250;</button>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- ── Drag divider ──────────────────────────────────── -->
        <div class="split-pane-divider" id="batch-divider">
            <div class="divider-grip"></div>
        </div>

        <!-- ── BOTTOM: orders for selected batch ─────────────── -->
        <div class="split-pane-bottom">
            <div class="pane-toolbar">
                @if (selectedBatch != null)
                {
                    var (sc, sl) = BatchStatusInfo(selectedBatch.Status);
                    <span class="pane-title">
                        Orders — Batch #@selectedBatch.Id &nbsp;
                        <span class="badge @sc" style="font-size:10px;">@sl</span>
                    </span>
                    @if (selectedBatch.Status == 2 && selectedBatchDto != null)
                    {
                        <button class="btn btn-sm btn-outline-success ms-auto"
                                @onclick="() => DownloadBatch(selectedBatch)">⬇ Download</button>
                    }
                    else if (selectedBatch.Status == 0 || selectedBatch.Status == 1)
                    {
                        <button class="btn btn-sm btn-outline-danger ms-auto"
                                @onclick="() => PromptCancelBatch(selectedBatch)">Cancel Batch</button>
                    }
                    else if (selectedBatch.Status == -1)
                    {
                        <button class="btn btn-sm btn-outline-warning ms-auto"
                                @onclick="() => ContinueBatch(selectedBatch)">Continue Batch</button>
                    }
                }
                else
                {
                    <span class="pane-title text-muted">Select a batch above to view its orders</span>
                }
            </div>
            <div class="pane-scroll">
                @if (selectedBatch == null)
                {
                    <div class="empty-state">Click a row in the top pane.</div>
                }
                else if (selectedBatchDto == null)
                {
                    <div class="loading-state">Loading orders…</div>
                }
                else if (!(selectedBatchDto.Orders?.Any() ?? false))
                {
                    <div class="empty-state">No orders for this batch yet.</div>
                }
                else
                {
                    <table class="table table-sm table-xs-font mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>ID</th>
                                <th>External GUID</th>
                                <th>Requested</th>
                                <th>Downloaded</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in PagedOrders)
                            {
                                var (oc, ol) = OrderStatusInfo(o.Status ?? "");
                                <tr>
                                    <td>@o.Id</td>
                                    <td class="cell-guid">@(o.ExternalGuid?.ToString() ?? "—")</td>
                                    <td>@o.RequestedCodes</td>
                                    <td class="@(selectedBatchDto.Status == "Completed" && o.RequestedCodes != o.DownloadedCodes ? "text-mismatch" : "")">
                                        @o.DownloadedCodes
                                    </td>
                                    <td><span class="badge @oc">@ol</span></td>
                                    <td>@o.RecordDate.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                                    <td class="text-xs text-muted">@o.StatusMessage</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (OrderTotalPages > 1)
                    {
                        <div class="pagination-bar">
                            <button class="pg-btn" disabled="@(orderPage <= 1)"
                                    @onclick="() => orderPage--">&#8249;</button>
                            <span class="pg-info">@orderPage / @OrderTotalPages &nbsp;(total @(selectedBatchDto.Orders?.Count) orders)</span>
                            <button class="pg-btn" disabled="@(orderPage >= OrderTotalPages)"
                                    @onclick="() => orderPage++">&#8250;</button>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- ── "Order Codes" Modal ───────────────────────────────────── -->
@if (showModal)
{
    <div class="modal-overlay" @onmousedown="CloseModal">
        <div class="modal-dialog-box" @onmousedown:stopPropagation="true">
            <div class="modal-dialog-header">
                <span class="modal-dialog-title">Order Codes</span>
                <button class="modal-close-btn" @onclick="CloseModal">×</button>
            </div>
            <div class="modal-dialog-body">

                <!-- Type -->
                <div class="mb-2">
                    <label class="form-label form-label-sm">Type</label>
                    <select class="form-select form-select-sm" @onchange="OnTypeChange">
                        <option value="0" selected="@(selectedTypeVal == 0)">Pack</option>
                        <option value="1" selected="@(selectedTypeVal == 1)">Bundle</option>
                        <option value="3" selected="@(selectedTypeVal == 3)">Mastercase</option>
                    </select>
                </div>

                <!-- GTIN autocomplete (Pack / Bundle only) -->
                @if (selectedTypeVal != 3)
                {
                    <div class="mb-2" style="position:relative;">
                        <label class="form-label form-label-sm">GTIN / Product Name</label>
                        <input class="form-control form-control-sm"
                               placeholder="Type to search…"
                               value="@gtinInput"
                               @oninput="OnGtinInput" />
                        @if (filteredProducts != null && filteredProducts.Any())
                        {
                            <div class="gtin-dropdown">
                                @foreach (var p in filteredProducts)
                                {
                                    <div class="gtin-item" @onclick="() => SelectProduct(p)">
                                        @p.Gtin — @p.Name
                                    </div>
                                }
                            </div>
                        }
                        @if (modalForm.ProductId.HasValue)
                        {
                            <small class="text-muted">Product ID: @modalForm.ProductId selected ✓</small>
                        }
                    </div>
                }

                <!-- Codes count -->
                <div class="mb-2">
                    <label class="form-label form-label-sm">
                        Codes Count <span class="text-danger">*</span>
                    </label>
                    <input type="number" class="form-control form-control-sm @(!string.IsNullOrEmpty(codesCountError) ? "is-invalid" : "")"
                           min="1"
                           value="@codesCountInput"
                           @oninput="OnCodesCountInput" />
                    @if (!string.IsNullOrEmpty(codesCountError))
                    {
                        <div class="invalid-feedback">@codesCountError</div>
                    }
                </div>

                <!-- Factory -->
                <div class="mb-2">
                    <label class="form-label form-label-sm">Factory</label>
                    <select class="form-select form-select-sm"
                            disabled="@((factories?.Count() ?? 0) <= 1)"
                            @bind="selectedFactoryId">
                        <option value="0">— Select Factory —</option>
                        @foreach (var f in factories ?? Enumerable.Empty<Factory>())
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>
                    @if ((factories?.Count() ?? 0) == 1)
                    {
                        <small class="text-muted">Only one factory available — auto-selected.</small>
                    }
                </div>

                <!-- Marking Line -->
                <div class="mb-2">
                    <label class="form-label form-label-sm">Marking Line</label>
                    <select class="form-select form-select-sm"
                            disabled="@((markingLines?.Count() ?? 0) <= 1)"
                            @bind="selectedMarkingLineId">
                        <option value="0">— Select Line —</option>
                        @foreach (var ml in markingLines ?? Enumerable.Empty<MarkingLine>())
                        {
                            <option value="@ml.Id">@ml.Name</option>
                        }
                    </select>
                    @if ((markingLines?.Count() ?? 0) == 1)
                    {
                        <small class="text-muted">Only one line available — auto-selected.</small>
                    }
                </div>

                <!-- Description -->
                <div class="mb-2">
                    <label class="form-label form-label-sm">Description</label>
                    <input class="form-control form-control-sm" @bind="modalForm.Description" />
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="alert alert-danger py-1 px-2 text-sm mt-2">@modalError</div>
                }
            </div>
            <div class="modal-dialog-footer">
                <button class="btn btn-sm btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-sm btn-primary" disabled="@isSubmitting" @onclick="SubmitOrder">
                    @(isSubmitting ? "Creating…" : "Create Order")
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── Data ─────────────────────────────────────────────────────────────
    private IEnumerable<Batch>? batches;
    private Batch? selectedBatch;
    private BatchDTO? selectedBatchDto;
    private IEnumerable<Product>? allProducts;
    private IEnumerable<Factory>? factories;
    private IEnumerable<MarkingLine>? markingLines;

    // ── Pagination ────────────────────────────────────────────────────────
    private const int BatchPageSize = 20;
    private const int OrderPageSize = 5;
    private int batchPage = 1;
    private int orderPage = 1;

    private IEnumerable<Batch> PagedBatches =>
        (batches ?? Enumerable.Empty<Batch>())
        .OrderByDescending(b => b.Id)
        .Skip((batchPage - 1) * BatchPageSize).Take(BatchPageSize);

    private int BatchTotalPages =>
        (int)Math.Ceiling((batches?.Count() ?? 0) / (double)BatchPageSize);

    private IEnumerable<OrderDTO> PagedOrders =>
        (selectedBatchDto?.Orders ?? new List<OrderDTO>())
        .Skip((orderPage - 1) * OrderPageSize).Take(OrderPageSize);

    private int OrderTotalPages =>
        (int)Math.Ceiling((selectedBatchDto?.Orders?.Count ?? 0) / (double)OrderPageSize);

    // ── Auto-refresh ──────────────────────────────────────────────────────
    private CancellationTokenSource? _cts;
    private bool isRefreshing = false;
    private int refreshInterval = 5;

    // ── Split pane ────────────────────────────────────────────────────────
    private double topPct = 45;
    private DotNetObjectReference<Batches>? _selfRef;

    // ── Modal state ───────────────────────────────────────────────────────
    private bool showModal = false;
    private BatchCreateForm modalForm = new();
    private int selectedTypeVal = 0;
    private string gtinInput = string.Empty;
    private IEnumerable<Product>? filteredProducts;
    private int? codesCountInput;
    private string codesCountError = string.Empty;
    private int selectedFactoryId = 0;
    private int selectedMarkingLineId = 0;
    private string modalError = string.Empty;
    private bool isSubmitting = false;

    // ── Confirm dialog ────────────────────────────────────────────────────
    private bool showConfirm = false;
    private string confirmMessage = string.Empty;
    private Func<Task>? confirmAction;

    // ── Toasts ────────────────────────────────────────────────────────────
    private record ToastEntry(string Message, string CssClass);
    private List<ToastEntry> toasts = new();

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadBatchesAsync(), LoadMetadataAsync());
        _cts = new CancellationTokenSource();
        _ = AutoRefreshLoop(_cts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("initSplitPane", "batch-split-wrapper", "batch-divider", _selfRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _selfRef?.Dispose();
    }

    [JSInvokable]
    public void SetTopPaneHeight(double pct)
    {
        topPct = pct;
        StateHasChanged();
    }

    // ── Load ──────────────────────────────────────────────────────────────
    private async Task LoadBatchesAsync()
    {
        batches = await BatchService.GetBatchesAsync();
    }

    private async Task LoadMetadataAsync()
    {
        allProducts   = await ProductService.GetProductsAsync();
        factories     = await MetadataService.GetFactoriesAsync();
        markingLines  = await MetadataService.GetMarkingLinesAsync();

        if (factories?.Count() == 1)     selectedFactoryId    = factories.First().Id;
        if (markingLines?.Count() == 1)  selectedMarkingLineId = markingLines.First().Id;
    }

    // ── Auto-refresh ──────────────────────────────────────────────────────
    private async Task AutoRefreshLoop(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            bool hasActive = batches?.Any(b => b.Status == 0 || b.Status == 1) ?? false;
            refreshInterval = hasActive ? 5 : 30;

            try { await Task.Delay(TimeSpan.FromSeconds(refreshInterval), token); }
            catch (OperationCanceledException) { return; }

            isRefreshing = true;
            await InvokeAsync(StateHasChanged);

            try
            {
                batches = await BatchService.GetBatchesAsync();
                if (selectedBatch != null)
                {
                    selectedBatchDto = await BatchService.GetBatchByIdAsync(selectedBatch.Id);
                    selectedBatch = batches?.FirstOrDefault(b => b.Id == selectedBatch.Id) ?? selectedBatch;
                }
            }
            catch { /* silently keep stale data */ }

            isRefreshing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Select batch ──────────────────────────────────────────────────────
    private async Task SelectBatch(Batch batch)
    {
        selectedBatch = batch;
        selectedBatchDto = null;
        orderPage = 1;
        try
        {
            selectedBatchDto = await BatchService.GetBatchByIdAsync(batch.Id);
        }
        catch
        {
            ShowToast("Failed to load batch details.", "toast-error");
        }
    }

    // ── Cancel ────────────────────────────────────────────────────────────
    private void PromptCancelBatch(Batch batch)
    {
        confirmMessage = $"Cancel Batch #{batch.Id} ({BatchTypeLabel(batch.Type)})? This cannot be undone.";
        confirmAction  = async () =>
        {
            try
            {
                await BatchService.CancelBatchAsync(batch.Id);
                batches = await BatchService.GetBatchesAsync();
                if (selectedBatch?.Id == batch.Id)
                {
                    selectedBatchDto = await BatchService.GetBatchByIdAsync(batch.Id);
                    selectedBatch = batches?.FirstOrDefault(b => b.Id == batch.Id) ?? selectedBatch;
                }
                ShowToast($"Batch #{batch.Id} cancelled.", "toast-success");
            }
            catch
            {
                ShowToast("Cancel failed. Try again.", "toast-error");
            }
        };
        showConfirm = true;
    }

    private async Task ConfirmYes()
    {
        showConfirm = false;
        if (confirmAction != null) { await confirmAction(); confirmAction = null; }
    }

    // ── Continue ──────────────────────────────────────────────────────────
    private async Task ContinueBatch(Batch batch)
    {
        try
        {
            await BatchService.ContinueBatchAsync(batch.Id);
            batches = await BatchService.GetBatchesAsync();
            if (selectedBatch?.Id == batch.Id)
            {
                selectedBatchDto = await BatchService.GetBatchByIdAsync(batch.Id);
                selectedBatch = batches?.FirstOrDefault(b => b.Id == batch.Id) ?? selectedBatch;
            }
            ShowToast($"Batch #{batch.Id} continued.", "toast-success");
        }
        catch
        {
            ShowToast("Continue failed. Try again.", "toast-error");
        }
    }

    // ── Download ──────────────────────────────────────────────────────────
    private async Task DownloadBatch(Batch batch)
    {
        try
        {
            var result = await BatchService.DownloadBatchContentAsync(batch.Id, "user");
            if (result is Microsoft.AspNetCore.Mvc.FileContentResult file)
            {
                var name = $"codes_{BatchTypeLabel(batch.Type)}_{batch.Id}.txt";
                using var stream = new System.IO.MemoryStream(file.FileContents);
                using var streamRef = new DotNetStreamReference(stream);
                await JSRuntime.InvokeVoidAsync("downloadFileFromStream", name, streamRef);
                ShowToast("Download started.", "toast-success");
            }
        }
        catch { ShowToast("Download failed.", "toast-error"); }
    }

    // ── Modal ─────────────────────────────────────────────────────────────
    private void ShowOrderCodesModal()
    {
        modalForm             = new BatchCreateForm { Type = 0 };
        selectedTypeVal       = 0;
        gtinInput             = string.Empty;
        filteredProducts      = null;
        codesCountInput       = null;
        codesCountError       = string.Empty;
        modalError            = string.Empty;
        isSubmitting          = false;
        showModal             = true;

        if (factories?.Count()    == 1) selectedFactoryId     = factories.First().Id;
        if (markingLines?.Count() == 1) selectedMarkingLineId = markingLines.First().Id;
    }

    private void CloseModal() => showModal = false;

    private void OnTypeChange(ChangeEventArgs e)
    {
        selectedTypeVal       = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        modalForm.Type        = (sbyte)selectedTypeVal;
        modalForm.ProductId   = null;
        gtinInput             = string.Empty;
        filteredProducts      = null;
    }

    private void OnGtinInput(ChangeEventArgs e)
    {
        gtinInput = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(gtinInput)) { filteredProducts = null; return; }

        filteredProducts = allProducts?
            .Where(p => p.Type == selectedTypeVal)
            .Where(p => p.Gtin.Contains(gtinInput, StringComparison.OrdinalIgnoreCase)
                     || (p.Name?.Contains(gtinInput, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(8);
    }

    private void SelectProduct(Product p)
    {
        gtinInput          = $"{p.Gtin} — {p.Name}";
        modalForm.ProductId = p.Id;
        modalForm.Type      = (sbyte)p.Type;
        filteredProducts   = null;
    }

    private void OnCodesCountInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            codesCountInput = val;
            codesCountError = val <= 0 ? "Must be greater than 0." : string.Empty;
        }
        else
        {
            codesCountInput = null;
            codesCountError = "Enter a number.";
        }
    }

    private async Task SubmitOrder()
    {
        // Validate
        if (!codesCountInput.HasValue || codesCountInput <= 0)
        {
            codesCountError = "Codes count is required and must be greater than 0.";
            return;
        }
        if (selectedTypeVal != 3 && !modalForm.ProductId.HasValue)
        {
            modalError = "Please select a product.";
            return;
        }

        modalForm.CodesCount = codesCountInput!.Value;
        modalForm.Type       = (sbyte)selectedTypeVal;
        modalForm.User       = "user";
        modalError           = string.Empty;
        isSubmitting         = true;

        try
        {
            var created = await BatchService.CreateBatchAsync(modalForm);
            batches = await BatchService.GetBatchesAsync();
            showModal = false;
            ShowToast($"Batch #{created?.Id} created.", "toast-success");
        }
        catch (Exception ex)
        {
            modalError = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────
    private static string BatchTypeLabel(int type) => type switch
    {
        0 => "Pack", 1 => "Bundle", 3 => "Mastercase", _ => $"Type{type}"
    };

    private static (string css, string label) BatchStatusInfo(int status) => status switch
    {
        -1 => ("badge-canceled",   "Canceled"),
         0 => ("badge-created",    "Created"),
         1 => ("badge-processing", "Processing"),
         2 => ("badge-completed",  "Completed"),
         _ => ("badge-unknown",    $"Status {status}")
    };

    private static (string css, string label) OrderStatusInfo(string status) => status switch
    {
        "External Failed"      => ("badge-error",      "Ext. Failed"),
        "External Saved_error" => ("badge-error",      "Ext. Save Err"),
        "Sending error"        => ("badge-error",      "Send Error"),
        "Created"              => ("badge-created",    "Created"),
        "Sent"                 => ("badge-info",       "Sent"),
        "Received"             => ("badge-info",       "Received"),
        "Executing"            => ("badge-processing", "Executing"),
        "Ready"                => ("badge-ready",      "Ready"),
        "Done"                 => ("badge-completed",  "Done"),
        _                      => ("badge-unknown",    status)
    };

    private async void ShowToast(string message, string cssClass)
    {
        var entry = new ToastEntry(message, cssClass);
        toasts.Add(entry);
        await InvokeAsync(StateHasChanged);
        await Task.Delay(4000);
        toasts.Remove(entry);
        await InvokeAsync(StateHasChanged);
    }
}
