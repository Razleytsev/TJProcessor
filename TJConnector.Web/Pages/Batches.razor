@page "/batches"
@attribute [Authorize]
@using TJConnector.SharedLibrary.DTOs.Forms
@using TJConnector.SharedLibrary.Models
@using TJConnector.Postgres.Entities
@implements IAsyncDisposable
@inject IBatchServiceWeb BatchService
@inject IProductService ProductService
@inject IMetadataService MetadataService
@inject IJSRuntime JSRuntime

<PageTitle>Order Batches · Abdulla</PageTitle>

<!-- ── Toast container ──────────────────────────────────────── -->
<div class="toast-container" aria-live="polite" aria-atomic="true">
    @foreach (var t in toasts)
    {
        <div class="co-toast @(t.CssClass == "toast-error" ? "co-toast-error" : "co-toast-success")" role="status">
            <span class="toast-msg">@t.Message</span>
            <button class="toast-close co-btn-icon" type="button"
                    aria-label="Dismiss notification"
                    @onclick="() => DismissToast(t)">×</button>
        </div>
    }
</div>

<!-- ── Confirm dialog ────────────────────────────────────────── -->
@if (showConfirm)
{
    @* B14: standardise cancel-confirm dialog — destructive primary verb on
       one side, neutral "Cancel" (the escape hatch) on the other. *@
    <div class="modal-overlay co-modal-overlay" tabindex="-1" @onkeydown="OnConfirmKey">
        <div class="confirm-box co-modal" role="alertdialog" aria-modal="true" aria-labelledby="confirm-title">
            <div class="co-modal-body">
                <p id="confirm-title" class="mb-3">@confirmMessage</p>
                <div class="co-modal-foot">
                    <button class="btn btn-sm btn-outline co-btn co-btn-default co-btn-sm" @onclick="() => showConfirm = false" autofocus>Cancel</button>
                    <button class="btn btn-sm btn-danger co-btn co-btn-danger co-btn-sm" @onclick="ConfirmYes">Yes, Cancel Batch</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Page root ─────────────────────────────────────────────── -->
<div class="page-root-flex">

    <!-- Header -->
    <div class="page-header co-page-header">
        <h1 class="page-title mb-0">Order Batches</h1>
        <div class="d-flex align-items-center gap-2 ms-auto co-actions">
            <span class="refresh-pill @(isRefreshing ? "is-refreshing" : "") co-status co-dot-secondary"
                  title="Auto-refreshes every @refreshInterval s">
                <span class="refresh-dot co-dot" aria-hidden="true"></span>
                @refreshInterval s
            </span>
            <button class="btn btn-sm btn-primary co-btn co-btn-primary co-btn-sm" @onclick="ShowOrderCodesModal">+ Order Codes</button>
        </div>
    </div>

    <!-- Split pane -->
    <div class="split-pane-wrapper" id="batch-split-wrapper">

        @* TJ-jerk fix: the top pane keeps the SAME fixed height whether or not a
           batch is selected, and the divider + bottom (orders) pane stay laid
           out at all times — so selecting / closing a batch no longer reflows
           the batch list. While nothing is selected the bottom pane holds a calm
           placeholder. *@
        <!-- ── TOP: batch list ───────────────────────────────── -->
        <div class="split-pane-top" style="flex: 0 0 @(topPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%; max-height: 100%;">
            @{
                var batchCount = batches?.Count() ?? 0;
            }
            @if (batches == null || batchCount > 0)
            {
                <div class="pane-toolbar">
                    <span class="pane-title">Batches (@batchCount)</span>
                </div>
            }
            <div class="pane-scroll">
                @if (batches == null)
                {
                    <div class="loading-state">Loading batches…</div>
                }
                else if (!batches.Any())
                {
                    <div class="empty-state">No batches. Click "+ Order Codes" to create one.</div>
                }
                else
                {
                    <table class="table table-sm table-xs-font table-hover mb-0 co-table">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th class="col-id">ID</th>
                                <th class="col-type">Type</th>
                                <th class="col-gtin">GTIN</th>
                                <th class="col-num">Count</th>
                                <th>Description</th>
                                <th class="col-user">User</th>
                                <th class="col-date">Date</th>
                                <th class="col-status">Status</th>
                                <th class="col-actions"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in PagedBatches)
                            {
                                var (sc, sl) = BatchStatusInfo(b.Status);
                                <tr class="@(selectedBatch?.Id == b.Id ? "highlighted-row co-row-active" : "") co-row-clickable"
                                    style="cursor:pointer;" @onclick="() => SelectBatch(b)">
                                    <td class="col-id co-mono">@b.Id</td>
                                    <td class="col-type">@BatchTypeLabel(b.Type)</td>
                                    @if (!string.IsNullOrEmpty(b.Product?.Gtin))
                                    {
                                        <td class="col-gtin co-mono co-copy-cell" style="white-space:nowrap;" data-co-copy="@b.Product!.Gtin">@b.Product!.Gtin</td>
                                    }
                                    else
                                    {
                                        <td class="col-gtin co-mono" style="white-space:nowrap;">—</td>
                                    }
                                    <td class="col-num co-tnum">@b.Count</td>
                                    @if (!string.IsNullOrEmpty(b.Description))
                                    {
                                        <td class="co-copy-cell" data-co-copy="@b.Description">@b.Description</td>
                                    }
                                    else
                                    {
                                        <td>@b.Description</td>
                                    }
                                    <td class="col-user">@(b.User ?? "—")</td>
                                    <td class="col-date co-tnum">@b.RecordDate.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                                    <td class="col-status"><span class="co-status @sc"><span class="co-dot"></span>@sl</span></td>
                                    <td class="cell-actions col-actions" @onclick:stopPropagation="true">
                                        @if (b.Status == 0 || b.Status == 1)
                                        {
                                            <button class="btn-xs btn btn-outline-danger co-btn co-btn-danger co-btn-sm"
                                                    @onclick="() => PromptCancelBatch(b)">Cancel</button>
                                        }
                                        @if (b.Status == 2)
                                        {
                                            <button class="btn-xs btn btn-outline-success co-btn co-btn-default co-btn-sm"
                                                    aria-label="Download batch @b.Id"
                                                    title="Download codes"
                                                    @onclick="() => DownloadBatch(b)">Download</button>
                                        }
                                        @if (b.Status == -1)
                                        {
                                            <button class="btn-xs btn btn-outline-warning co-btn co-btn-default co-btn-sm"
                                                    @onclick="() => ContinueBatch(b)">Continue</button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (BatchTotalPages > 1)
                    {
                        @* A1: unified CalmOps pager |‹ ‹ n of m (x batches) › ›|. *@
                        <div class="co-pager-footer">
                            <CoPager Page="batchPage" TotalPages="BatchTotalPages"
                                     TotalCount="@(batches?.Count() ?? 0)" ResultNoun="batch"
                                     OnPageChange="@(p => batchPage = p)" />
                        </div>
                    }
                }
            </div>
        </div>

        @* Divider + orders pane are ALWAYS present (space reserved) so the list
           above never jerks when a batch opens/closes. The divider is non-
           interactive (faded) while nothing is selected. *@
        <!-- ── Drag divider ──────────────────────────────────── -->
        <div class="split-pane-divider @(selectedBatch == null ? "is-inert" : "")" id="batch-divider">
            <div class="divider-grip"></div>
        </div>

        <!-- ── BOTTOM: orders for selected batch ─────────────── -->
        <div class="split-pane-bottom">
            @if (selectedBatch == null)
            {
                <div class="co-detail-placeholder">Select a batch to view its orders.</div>
            }
            else
            {
                var (sc, sl) = BatchStatusInfo(selectedBatch.Status);
            <div class="pane-toolbar">
                <span class="pane-title">
                    Orders — Batch #@selectedBatch.Id &nbsp;
                    <span class="co-status @sc"><span class="co-dot"></span>@sl</span>
                </span>
                @if (selectedBatch.Status == 2 && selectedBatchDto != null)
                {
                    <button class="btn btn-sm btn-outline-success ms-auto co-btn co-btn-default co-btn-sm"
                            @onclick="() => DownloadBatch(selectedBatch)">Download</button>
                }
                else if (selectedBatch.Status == 0 || selectedBatch.Status == 1)
                {
                    <button class="btn btn-sm btn-outline-danger ms-auto co-btn co-btn-danger co-btn-sm"
                            @onclick="() => PromptCancelBatch(selectedBatch)">Cancel Batch</button>
                }
                else if (selectedBatch.Status == -1)
                {
                    <button class="btn btn-sm btn-outline-warning ms-auto co-btn co-btn-default co-btn-sm"
                            @onclick="() => ContinueBatch(selectedBatch)">Continue Batch</button>
                }
                <button class="btn-icon ms-2 co-btn-icon" aria-label="Close orders pane" title="Close"
                        @onclick="() => { selectedBatch = null; selectedBatchDto = null; }">×</button>
            </div>
            <div class="pane-scroll">
                @if (selectedBatchDto == null)
                {
                    <div class="loading-state">Loading orders…</div>
                }
                else if (!(selectedBatchDto.Orders?.Any() ?? false))
                {
                    <div class="empty-state">No orders for this batch yet.</div>
                }
                else
                {
                    <table class="table table-sm table-xs-font mb-0 co-table">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>ID</th>
                                <th>External GUID</th>
                                <th>Requested</th>
                                <th>Downloaded</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in PagedOrders)
                            {
                                var (oc, ol) = OrderStatusInfo(o.Status ?? "");
                                <tr>
                                    <td class="co-mono co-copy-cell" data-co-copy="@o.Id">@o.Id</td>
                                    @if (o.ExternalGuid.HasValue)
                                    {
                                        <td class="cell-guid co-mono co-copy-cell" data-co-copy="@o.ExternalGuid.ToString()">@o.ExternalGuid.ToString()</td>
                                    }
                                    else
                                    {
                                        <td class="cell-guid co-mono">—</td>
                                    }
                                    <td class="co-tnum">@o.RequestedCodes</td>
                                    <td class="co-tnum @(selectedBatchDto.Status == "Completed" && o.RequestedCodes != o.DownloadedCodes ? "text-mismatch" : "")">
                                        @o.DownloadedCodes
                                    </td>
                                    <td><span class="co-status @oc"><span class="co-dot"></span>@ol</span></td>
                                    <td class="co-tnum">@o.RecordDate.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                                    @if (!string.IsNullOrEmpty(o.StatusMessage))
                                    {
                                        <td class="text-xs text-muted co-muted co-copy-cell" data-co-copy="@o.StatusMessage">@o.StatusMessage</td>
                                    }
                                    else
                                    {
                                        <td class="text-xs text-muted co-muted">@o.StatusMessage</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (OrderTotalPages > 1)
                    {
                        @* A1: unified CalmOps pager |‹ ‹ n of m (x orders) › ›|. *@
                        <div class="co-pager-footer">
                            <CoPager Page="orderPage" TotalPages="OrderTotalPages"
                                     TotalCount="@(selectedBatchDto.Orders?.Count ?? 0)" ResultNoun="order"
                                     OnPageChange="@(p => orderPage = p)" />
                        </div>
                    }
                }
            </div>
            }
        </div>
    </div>
</div>

<!-- ── "Order Codes" Modal ───────────────────────────────────── -->
@if (showModal)
{
    <div class="modal-overlay co-modal-overlay" tabindex="-1" @onmousedown="CloseModal" @onkeydown="OnModalKey">
        <div class="modal-dialog-box co-modal" role="dialog" aria-modal="true" aria-labelledby="order-codes-title"
             @onmousedown:stopPropagation="true">
            <div class="modal-dialog-header co-modal-head">
                <span class="modal-dialog-title" id="order-codes-title">Order Codes</span>
                <button class="modal-close-btn co-btn-icon" type="button" aria-label="Close dialog" @onclick="CloseModal">×</button>
            </div>
            <div class="modal-dialog-body co-modal-body">

                <!-- Type -->
                <div class="mb-2">
                    <label class="form-label form-label-sm" for="fld-type">Type</label>
                    <select id="fld-type" class="form-select form-select-sm co-select" @onchange="OnTypeChange">
                        <option value="0" selected="@(selectedTypeVal == 0)">Pack</option>
                        <option value="1" selected="@(selectedTypeVal == 1)">Bundle</option>
                        <option value="3" selected="@(selectedTypeVal == 3)">Mastercase</option>
                    </select>
                </div>

                <!-- GTIN autocomplete (Pack / Bundle only) -->
                @if (selectedTypeVal != 3)
                {
                    <div class="mb-2" style="position:relative;">
                        <label class="form-label form-label-sm" for="fld-gtin">GTIN / Product Name</label>
                        <input id="fld-gtin" class="form-control form-control-sm co-input"
                               placeholder="Type to search…"
                               value="@gtinInput"
                               @oninput="OnGtinInput" />
                        @if (filteredProducts != null && filteredProducts.Any())
                        {
                            <div class="gtin-dropdown">
                                @foreach (var p in filteredProducts)
                                {
                                    <div class="gtin-item" @onclick="() => SelectProduct(p)">
                                        @p.Gtin — @p.Name
                                    </div>
                                }
                            </div>
                        }
                        @if (modalForm.ProductId.HasValue)
                        {
                            <small class="text-muted">Product ID: @modalForm.ProductId selected ✓</small>
                        }
                    </div>
                }

                <!-- Codes count -->
                <div class="mb-2">
                    <label class="form-label form-label-sm" for="fld-count">
                        Codes Count <span class="required-mark" aria-hidden="true">*</span>
                    </label>
                    <input id="fld-count" type="number" class="form-control form-control-sm co-input @(!string.IsNullOrEmpty(codesCountError) ? "is-invalid" : "")"
                           min="1"
                           value="@codesCountInput"
                           @oninput="OnCodesCountInput"
                           aria-required="true" />
                    @if (!string.IsNullOrEmpty(codesCountError))
                    {
                        <div class="invalid-feedback">@codesCountError</div>
                    }
                </div>

                <!-- Factory -->
                <div class="mb-2">
                    <label class="form-label form-label-sm" for="fld-factory">Factory</label>
                    <select id="fld-factory" class="form-select form-select-sm co-select"
                            disabled="@((factories?.Count() ?? 0) <= 1)"
                            @bind="selectedFactoryId">
                        <option value="0">— Select Factory —</option>
                        @foreach (var f in factories ?? Enumerable.Empty<Factory>())
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>
                    @if ((factories?.Count() ?? 0) == 1)
                    {
                        <small class="text-muted">Only one factory available — auto-selected.</small>
                    }
                </div>

                <!-- Marking Line -->
                <div class="mb-2">
                    <label class="form-label form-label-sm" for="fld-line">Marking Line</label>
                    <select id="fld-line" class="form-select form-select-sm co-select"
                            disabled="@((markingLines?.Count() ?? 0) <= 1)"
                            @bind="selectedMarkingLineId">
                        <option value="0">— Select Line —</option>
                        @foreach (var ml in markingLines ?? Enumerable.Empty<MarkingLine>())
                        {
                            <option value="@ml.Id">@ml.Name</option>
                        }
                    </select>
                    @if ((markingLines?.Count() ?? 0) == 1)
                    {
                        <small class="text-muted">Only one line available — auto-selected.</small>
                    }
                </div>

                <!-- Description -->
                <div class="mb-2">
                    <label class="form-label form-label-sm" for="fld-description">Description</label>
                    <input id="fld-description" class="form-control form-control-sm co-input" @bind="modalForm.Description" />
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="alert alert-danger py-1 px-2 text-sm mt-2 co-alert co-alert-error"><p>@modalError</p></div>
                }
            </div>
            <div class="modal-dialog-footer co-modal-foot">
                <button class="btn btn-sm btn-outline co-btn co-btn-default co-btn-sm" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-sm btn-primary co-btn co-btn-primary co-btn-sm" disabled="@isSubmitting" @onclick="SubmitOrder">
                    @(isSubmitting ? "Creating…" : "Create Order")
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── Data ─────────────────────────────────────────────────────────────
    private IEnumerable<Batch>? batches;
    private Batch? selectedBatch;
    private BatchDTO? selectedBatchDto;
    private IEnumerable<Product>? allProducts;
    private IEnumerable<Factory>? factories;
    private IEnumerable<MarkingLine>? markingLines;

    // ── Pagination ────────────────────────────────────────────────────────
    private const int BatchPageSize = 20;
    private const int OrderPageSize = 5;
    private int batchPage = 1;
    private int orderPage = 1;

    private IEnumerable<Batch> PagedBatches =>
        (batches ?? Enumerable.Empty<Batch>())
        .OrderByDescending(b => b.Id)
        .Skip((batchPage - 1) * BatchPageSize).Take(BatchPageSize);

    private int BatchTotalPages =>
        (int)Math.Ceiling((batches?.Count() ?? 0) / (double)BatchPageSize);

    private IEnumerable<OrderDTO> PagedOrders =>
        (selectedBatchDto?.Orders ?? new List<OrderDTO>())
        .Skip((orderPage - 1) * OrderPageSize).Take(OrderPageSize);

    private int OrderTotalPages =>
        (int)Math.Ceiling((selectedBatchDto?.Orders?.Count ?? 0) / (double)OrderPageSize);

    // ── Auto-refresh ──────────────────────────────────────────────────────
    private CancellationTokenSource? _cts;
    private bool isRefreshing = false;
    private int refreshInterval = 5;

    // ── Split pane ────────────────────────────────────────────────────────
    private double topPct = 45;
    private DotNetObjectReference<Batches>? _selfRef;

    // ── Modal state ───────────────────────────────────────────────────────
    private bool showModal = false;
    private BatchCreateForm modalForm = new();
    private int selectedTypeVal = 0;
    private string gtinInput = string.Empty;
    private IEnumerable<Product>? filteredProducts;
    private int? codesCountInput;
    private string codesCountError = string.Empty;
    private int selectedFactoryId = 0;
    private int selectedMarkingLineId = 0;
    private string modalError = string.Empty;
    private bool isSubmitting = false;

    // ── Confirm dialog ────────────────────────────────────────────────────
    private bool showConfirm = false;
    private string confirmMessage = string.Empty;
    private Func<Task>? confirmAction;

    // ── Toasts ────────────────────────────────────────────────────────────
    private record ToastEntry(string Message, string CssClass);
    private List<ToastEntry> toasts = new();

    // ── Lifecycle ─────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadBatchesAsync(), LoadMetadataAsync());
        _cts = new CancellationTokenSource();
        _ = AutoRefreshLoop(_cts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("initSplitPane", "batch-split-wrapper", "batch-divider", _selfRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _selfRef?.Dispose();
    }

    [JSInvokable]
    public void SetTopPaneHeight(double pct)
    {
        topPct = pct;
        StateHasChanged();
    }

    // ── Load ──────────────────────────────────────────────────────────────
    private async Task LoadBatchesAsync()
    {
        batches = await BatchService.GetBatchesAsync();
    }

    private async Task LoadMetadataAsync()
    {
        allProducts   = await ProductService.GetProductsAsync();
        factories     = await MetadataService.GetFactoriesAsync();
        markingLines  = await MetadataService.GetMarkingLinesAsync();

        if (factories?.Count() == 1)     selectedFactoryId    = factories.First().Id;
        if (markingLines?.Count() == 1)  selectedMarkingLineId = markingLines.First().Id;
    }

    // ── Auto-refresh ──────────────────────────────────────────────────────
    private async Task AutoRefreshLoop(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            bool hasActive = batches?.Any(b => b.Status == 0 || b.Status == 1) ?? false;
            refreshInterval = hasActive ? 5 : 30;

            try { await Task.Delay(TimeSpan.FromSeconds(refreshInterval), token); }
            catch (OperationCanceledException) { return; }

            isRefreshing = true;
            await InvokeAsync(StateHasChanged);

            try
            {
                batches = await BatchService.GetBatchesAsync();
                if (selectedBatch != null)
                {
                    selectedBatchDto = await BatchService.GetBatchByIdAsync(selectedBatch.Id);
                    selectedBatch = batches?.FirstOrDefault(b => b.Id == selectedBatch.Id) ?? selectedBatch;
                }
            }
            catch { /* silently keep stale data */ }

            isRefreshing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Select batch ──────────────────────────────────────────────────────
    private async Task SelectBatch(Batch batch)
    {
        selectedBatch = batch;
        selectedBatchDto = null;
        orderPage = 1;
        try
        {
            selectedBatchDto = await BatchService.GetBatchByIdAsync(batch.Id);
        }
        catch
        {
            ShowToast("Failed to load batch details.", "toast-error");
        }
    }

    // ── Cancel ────────────────────────────────────────────────────────────
    private void PromptCancelBatch(Batch batch)
    {
        confirmMessage = $"Cancel Batch #{batch.Id} ({BatchTypeLabel(batch.Type)})? This cannot be undone.";
        confirmAction  = async () =>
        {
            try
            {
                await BatchService.CancelBatchAsync(batch.Id);
                batches = await BatchService.GetBatchesAsync();
                if (selectedBatch?.Id == batch.Id)
                {
                    selectedBatchDto = await BatchService.GetBatchByIdAsync(batch.Id);
                    selectedBatch = batches?.FirstOrDefault(b => b.Id == batch.Id) ?? selectedBatch;
                }
                ShowToast($"Batch #{batch.Id} cancelled.", "toast-success");
            }
            catch
            {
                ShowToast("Cancel failed. Try again.", "toast-error");
            }
        };
        showConfirm = true;
    }

    private async Task ConfirmYes()
    {
        showConfirm = false;
        if (confirmAction != null) { await confirmAction(); confirmAction = null; }
    }

    // ── Continue ──────────────────────────────────────────────────────────
    private async Task ContinueBatch(Batch batch)
    {
        try
        {
            await BatchService.ContinueBatchAsync(batch.Id);
            batches = await BatchService.GetBatchesAsync();
            if (selectedBatch?.Id == batch.Id)
            {
                selectedBatchDto = await BatchService.GetBatchByIdAsync(batch.Id);
                selectedBatch = batches?.FirstOrDefault(b => b.Id == batch.Id) ?? selectedBatch;
            }
            ShowToast($"Batch #{batch.Id} continued.", "toast-success");
        }
        catch
        {
            ShowToast("Continue failed. Try again.", "toast-error");
        }
    }

    // ── Download ──────────────────────────────────────────────────────────
    private async Task DownloadBatch(Batch batch)
    {
        try
        {
            var result = await BatchService.DownloadBatchContentAsync(batch.Id, "user");
            if (result is Microsoft.AspNetCore.Mvc.FileContentResult file)
            {
                var name = $"codes_{BatchTypeLabel(batch.Type)}_{batch.Id}.txt";
                using var stream = new System.IO.MemoryStream(file.FileContents);
                using var streamRef = new DotNetStreamReference(stream);
                await JSRuntime.InvokeVoidAsync("downloadFileFromStream", name, streamRef);
                ShowToast("Download started.", "toast-success");
            }
        }
        catch { ShowToast("Download failed.", "toast-error"); }
    }

    // ── Modal ─────────────────────────────────────────────────────────────
    private void ShowOrderCodesModal()
    {
        modalForm             = new BatchCreateForm { Type = 0 };
        selectedTypeVal       = 0;
        gtinInput             = string.Empty;
        filteredProducts      = null;
        codesCountInput       = null;
        codesCountError       = string.Empty;
        modalError            = string.Empty;
        isSubmitting          = false;
        showModal             = true;

        if (factories?.Count()    == 1) selectedFactoryId     = factories.First().Id;
        if (markingLines?.Count() == 1) selectedMarkingLineId = markingLines.First().Id;
    }

    private void CloseModal() => showModal = false;

    private void OnModalKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") CloseModal();
    }

    private void OnConfirmKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") showConfirm = false;
    }

    private void OnTypeChange(ChangeEventArgs e)
    {
        selectedTypeVal       = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        modalForm.Type        = (sbyte)selectedTypeVal;
        modalForm.ProductId   = null;
        gtinInput             = string.Empty;
        filteredProducts      = null;
    }

    private void OnGtinInput(ChangeEventArgs e)
    {
        gtinInput = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(gtinInput)) { filteredProducts = null; return; }

        filteredProducts = allProducts?
            .Where(p => p.Type == selectedTypeVal)
            .Where(p => p.Gtin.Contains(gtinInput, StringComparison.OrdinalIgnoreCase)
                     || (p.Name?.Contains(gtinInput, StringComparison.OrdinalIgnoreCase) ?? false))
            .Take(8);
    }

    private void SelectProduct(Product p)
    {
        gtinInput          = $"{p.Gtin} — {p.Name}";
        modalForm.ProductId = p.Id;
        modalForm.Type      = (sbyte)p.Type;
        filteredProducts   = null;
    }

    private void OnCodesCountInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            codesCountInput = val;
            codesCountError = val <= 0 ? "Must be greater than 0." : string.Empty;
        }
        else
        {
            codesCountInput = null;
            codesCountError = "Enter a number.";
        }
    }

    private async Task SubmitOrder()
    {
        // Validate
        if (!codesCountInput.HasValue || codesCountInput <= 0)
        {
            codesCountError = "Codes count is required and must be greater than 0.";
            return;
        }
        if (selectedTypeVal != 3 && !modalForm.ProductId.HasValue)
        {
            modalError = "Please select a product.";
            return;
        }

        modalForm.CodesCount = codesCountInput!.Value;
        modalForm.Type       = (sbyte)selectedTypeVal;
        modalForm.User       = "user";
        modalError           = string.Empty;
        isSubmitting         = true;

        try
        {
            var created = await BatchService.CreateBatchAsync(modalForm);
            batches = await BatchService.GetBatchesAsync();
            showModal = false;
            ShowToast($"Batch #{created?.Id} created.", "toast-success");
        }
        catch (Exception ex)
        {
            modalError = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────
    private static string BatchTypeLabel(int type) => type switch
    {
        0 => "Pack", 1 => "Bundle", 3 => "Mastercase", _ => $"Type{type}"
    };

    // Returns (CalmOps dot-tone class, friendly label). The 8px dot carries the
    // color; the label stays calm slate (no filled pill).
    private static (string css, string label) BatchStatusInfo(int status) => status switch
    {
        -1 => ("co-dot-danger",    "Canceled"),
         0 => ("co-dot-info",      "Created"),
         1 => ("co-dot-primary",   "Processing"),
         2 => ("co-dot-success",   "Completed"),
         _ => ("co-dot-secondary", $"Status {status}")
    };

    private static (string css, string label) OrderStatusInfo(string status) => status switch
    {
        "External Failed"      => ("co-dot-danger",    "Ext. Failed"),
        "External Saved_error" => ("co-dot-danger",    "Ext. Save Err"),
        "Sending error"        => ("co-dot-danger",    "Send Error"),
        "Created"              => ("co-dot-info",      "Created"),
        "Sent"                 => ("co-dot-info",       "Sent"),
        "Received"             => ("co-dot-info",       "Received"),
        "Executing"            => ("co-dot-primary",   "Executing"),
        "Ready"                => ("co-dot-warning",    "Ready"),
        "Done"                 => ("co-dot-success",   "Done"),
        _                      => ("co-dot-secondary", status)
    };

    private async void ShowToast(string message, string cssClass)
    {
        var entry = new ToastEntry(message, cssClass);
        toasts.Add(entry);
        await InvokeAsync(StateHasChanged);
        var lifetimeMs = cssClass == "toast-error" ? 8000 : 4000;
        await Task.Delay(lifetimeMs);
        if (toasts.Contains(entry))
        {
            toasts.Remove(entry);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void DismissToast(ToastEntry entry)
    {
        toasts.Remove(entry);
    }
}
