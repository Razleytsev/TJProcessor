@page "/products"
@attribute [Authorize]
@inject IProductService ProductService

<PageTitle>Products · Abdulla</PageTitle>

<div class="page-header">
    <h1 class="page-title mb-0">Products</h1>
</div>

<div class="container products-page">
    <div class="table-container co-table-scroll" style="flex:1;min-width:0;font-size: 12px;">
        @if (products == null)
        {
            <div class="loading-state">Loading products…</div>
        }
        else
        {
            <CustomTable Items="products"
                         Columns="columns"
                         CopyableCells="true"
                         OnRowClick="EventCallback.Factory.Create<Product>(this, OnProductClick)"
                         SelectedItem="selectedProduct" />
        }
    </div>
    @* TJ-jerk fix: the details panel is ALWAYS laid out (fixed 380px column) so
       selecting / clearing a product never reflows the table. While nothing is
       selected the column holds a calm placeholder instead of collapsing.
       B2: gate only the body content on the external-API result. *@
    <div class="details-container" style="flex:0 0 380px;font-size: 12px;">
        @if (selectedProduct == null)
        {
            <div class="co-detail-placeholder">Select a product to view its external information.</div>
        }
        else
        {
            <div class="d-flex align-items-center justify-content-between mb-2">
                <h4 style="margin:0;font-size:0.82rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);">External Product Information</h4>
                <button class="btn-icon" aria-label="Close details" title="Close" @onclick="ClearSelection">×</button>
            </div>
            @if (isLoadingExternal)
            {
                <div class="loading-state" style="justify-content:flex-start;padding:0.5rem 0;">Loading external info…</div>
            }
            else if (selectedProductExternalInfo != null)
            {
                <p><strong>Name:</strong> <span class="co-copy-cell" data-co-copy="@selectedProductExternalInfo.name">@selectedProductExternalInfo.name</span></p>
                <p><strong>GTIN:</strong> <span class="co-copy-cell" data-co-copy="@selectedProductExternalInfo.gtin">@selectedProductExternalInfo.gtin</span></p>
                <p><strong>Manufacturer:</strong> <span class="co-copy-cell" data-co-copy="@selectedProductExternalInfo.manufacturerName">@selectedProductExternalInfo.manufacturerName</span></p>
                <p><strong>Weight (Gross):</strong> <span class="co-copy-cell" data-co-copy="@selectedProductExternalInfo.weightGross">@selectedProductExternalInfo.weightGross</span></p>
                <p><strong>Dimensions:</strong> <span class="co-copy-cell" data-co-copy="@($"{selectedProductExternalInfo.length} x {selectedProductExternalInfo.width} x {selectedProductExternalInfo.height}")">@selectedProductExternalInfo.length x @selectedProductExternalInfo.width x @selectedProductExternalInfo.height</span></p>
                <p><strong>Storage Conditions:</strong> <span class="co-copy-cell" data-co-copy="@selectedProductExternalInfo.storageConditions">@selectedProductExternalInfo.storageConditions</span></p>
                <p><strong>Composition:</strong> <span class="co-copy-cell" data-co-copy="@selectedProductExternalInfo.composition">@selectedProductExternalInfo.composition</span></p>
                <p><strong>Country of Origin:</strong> <span class="co-copy-cell" data-co-copy="@selectedProductExternalInfo.productCountryOfOrigin">@selectedProductExternalInfo.productCountryOfOrigin</span></p>
            }
            else
            {
                <div class="alert alert-warning" role="alert" style="margin:0;">
                    <strong>External info unavailable.</strong>
                    @if (!string.IsNullOrEmpty(externalError))
                    {
                        <div class="text-xs" style="margin-top:0.35rem;">@externalError</div>
                    }
                    else
                    {
                        <div class="text-xs" style="margin-top:0.35rem;">The marking-authority API didn't return data for this product.</div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    private IEnumerable<Product>? products;
    private List<CustomTable<Product>.ColumnDefinition<Product>> columns = new();
    private ProductInfoResponse? selectedProductExternalInfo;
    private Product? selectedProduct;
    private bool isLoadingExternal;
    private string? externalError;

    protected override void OnInitialized()
    {
        // Build columns BEFORE the first render so headers exist even while
        // products are still loading (so the table is always present).
        columns = new()
        {
            new() { Header = "ID", Value = p => p.Id },
            new() { Header = "Name", Value = p => p.Name },
            new() { Header = "GTIN", Value = p => p.Gtin },
            new() { Header = "Type", Value = p => GetProductTypeString(p.Type) },
            new() { Header = "External UUID", Value = p => p.ExternalUid },
            new() { Header = "Record Date", Value = p => LTime(p.RecordDate) }
        };
    }

    protected override async Task OnInitializedAsync()
    {
        // Render local data first — the external mark.tj sync below can take
        // up to ~45 s (3 Polly retries × 15 s timeouts) and used to leave the
        // page stuck on "Loading products…" the whole time.
        try
        {
            products = await ProductService.GetProductsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching products: {ex.Message}");
        }

        // Fire-and-forget the external sync. When it completes (or fails),
        // refresh the local list so any newly-imported products show up.
        _ = Task.Run(async () =>
        {
            try
            {
                await ProductService.GetExternalProductsAsync();
                var fresh = await ProductService.GetProductsAsync();
                await InvokeAsync(() =>
                {
                    products = fresh;
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Background external-products sync failed: {ex.Message}");
            }
        });
    }

    private void ClearSelection()
    {
        selectedProduct = null;
        selectedProductExternalInfo = null;
        externalError = null;
        isLoadingExternal = false;
    }

    private async Task OnProductClick(Product product)
    {
        selectedProduct = product;
        selectedProductExternalInfo = null;
        externalError = null;
        isLoadingExternal = true;
        StateHasChanged();
        try
        {
            var result = await ProductService.GetExternalProductByIdAsync(product.ExternalUid.ToString());
            if (result.Success && result.Content != null)
            {
                selectedProductExternalInfo = result.Content;
            }
            else
            {
                externalError = string.IsNullOrEmpty(result.Message)
                    ? "External API returned no data."
                    : result.Message;
                Console.WriteLine("Failed to fetch external product info: " + result.Message);
            }
        }
        catch (Exception ex)
        {
            externalError = ex.Message;
            Console.WriteLine($"Error fetching external product info: {ex.Message}");
        }
        finally
        {
            isLoadingExternal = false;
        }
    }

    public string LTime(DateTimeOffset time)
    {
        // B5: tables use the same compact format everywhere — dd.MM.yy HH:mm.
        return time.ToLocalTime().ToString("dd.MM.yy HH:mm");
    }
    private string GetProductTypeString(int type)
    {
        return type switch
        {
            0 => "Pack",
            1 => "Bundle",
            3 => "Mastercase",
            _ => "Unknown"
        };
    }
}