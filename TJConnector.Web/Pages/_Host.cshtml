@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace TJConnector.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
        // Mobile only: serve the full unscaled DESKTOP layout (fit-to-width, pan/zoom)
        // instead of adapting to the phone. Desktop browsers keep width=device-width.
        if (/Mobi|Android|iPhone|iPad|iPod|IEMobile|Opera Mini|Windows Phone/i.test(navigator.userAgent)) {
            var _vp = document.querySelector('meta[name="viewport"]');
            if (_vp) _vp.setAttribute('content', 'width=1280');
        }
    </script>
    <base href="~/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" asp-append-version="true" />
    <link href="css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="css/calmops/colors_and_type.css" rel="stylesheet" asp-append-version="true" />
    <link href="css/calmops/components.css" rel="stylesheet" asp-append-version="true" />
    <link href="TJConnector.Web.styles.css" rel="stylesheet" asp-append-version="true" />
    <style>
        /* CalmOps accent lock for TJ: the canonical single accent is #2563eb.
           The shared components.css uses --action-primary (#2f62c4); pin the
           primary button + focus rings to #2563eb here (loaded last → wins). */
        .co-btn-primary {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }
        .co-btn-primary:hover {
            background: #1d4ed8;
            border-color: #1d4ed8;
        }
        .co-btn:focus-visible,
        .co-input:focus {
            outline-color: #2563eb;
            border-color: #2563eb;
        }
        .co-input:focus {
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }
        /* Headings are display-only — never interactive. ServerPrerendered/
           FocusOnNavigate can give a heading a tabindex and focus it on load,
           which the components.css [tabindex]:focus-visible a11y rule then
           paints with a blue outline (making "Sign in" look like an input).
           Suppress outline/box-shadow/border on headings in every focus state.
           This loads after components.css so it wins; interactive elements
           (.co-btn, .co-input, links) keep their focus ring untouched. */
        h1, h2, h3, h4, h5, h6,
        h1:focus, h2:focus, h3:focus, h4:focus, h5:focus, h6:focus,
        h1:focus-visible, h2:focus-visible, h3:focus-visible,
        h4:focus-visible, h5:focus-visible, h6:focus-visible {
            outline: none;
            box-shadow: none;
            border: none;
        }
        /* Centered login card sizing (replaces the legacy .login-box box-model). */
        .login-card {
            width: 360px;
            max-width: 92vw;
            padding: 2.25rem 2.5rem;
        }
    </style>
    <link rel="icon" type="image/svg+xml" href="brand/favicon.svg" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="brand/favicon-32.png" />
    <link rel="apple-touch-icon" href="brand/apple-touch-icon.png" />
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui"; style="
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: #fff;">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
    <script src="_framework/blazor.server.js"></script>
    <script>
        window.downloadFileFromStream = async (fileName, contentStreamReference) => {
            const arrayBuffer = await contentStreamReference.arrayBuffer();
            const blob = new Blob([arrayBuffer]);
            const url = URL.createObjectURL(blob);

            const anchorElement = document.createElement('a');
            anchorElement.href = url;
            anchorElement.download = fileName ?? '';
            anchorElement.click();
            anchorElement.remove();
            URL.revokeObjectURL(url);
        }
    </script>
    <script src="js/interop.js"></script>
    <script src="css/calmops/calm-ops.js" asp-append-version="true"></script>
</body>
</html>


