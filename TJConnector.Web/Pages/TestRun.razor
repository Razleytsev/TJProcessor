@page "/test-run"
@using Microsoft.Extensions.Configuration
@using TJConnector.Postgres.Entities
@using TJConnector.SharedLibrary.DTOs.Forms
@using TJConnector.SharedLibrary.Models
@using TJConnector.Web.Services.Implementation
@implements IAsyncDisposable
@inject ITestRunServiceWeb TestRunService
@inject IProductService ProductService
@inject IMetadataService MetadataService
@inject IConfiguration Configuration

<div class="page-root-flex" style="padding:12px;gap:12px;overflow-y:auto;">

    @if (!isEnabled)
    {
        <div class="alert alert-warning">
            <strong>Test Run is disabled</strong> in this environment.
            Set <code>TestRun.Enabled = true</code> in <code>appsettings.json</code> to enable.
        </div>
    }
    else
    {
        <h5>Production Contour Test Run</h5>
        <div class="text-xs text-muted" style="margin-bottom:8px;">
            Drives the full marking-authority chain (pack → bundle → mastercase → application → aggregation) against the
            real external system. Real codes are minted and cannot be reverted.
        </div>

        <div class="card" style="padding:12px;background:#f8f9fa;border:1px solid #e9ecef;border-radius:6px;">
            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Pack GTIN / Product</label>
                    <select class="form-select form-select-sm" @bind="form.PackProductId">
                        <option value="0">— select —</option>
                        @foreach (var p in packProducts)
                        {
                            <option value="@p.Id">@p.Gtin — @p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Bundle GTIN / Product</label>
                    <select class="form-select form-select-sm" @bind="form.BundleProductId">
                        <option value="0">— select —</option>
                        @foreach (var p in bundleProducts)
                        {
                            <option value="@p.Id">@p.Gtin — @p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Packs per bundle</label>
                    <input type="number" min="1" class="form-control form-control-sm" @bind="form.PacksPerBundle" />
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Bundles per container</label>
                    <input type="number" min="1" class="form-control form-control-sm" @bind="form.BundlesPerContainer" />
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">User</label>
                    <input class="form-control form-control-sm" @bind="form.User" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Factory</label>
                    <select class="form-select form-select-sm" @bind="factoryId" disabled="@(factories.Count() <= 1)">
                        <option value="0">— select —</option>
                        @foreach (var f in factories)
                        {
                            <option value="@f.Id">@f.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Marking line</label>
                    <select class="form-select form-select-sm" @bind="markingLineId" disabled="@(markingLines.Count() <= 1)">
                        <option value="0">— select —</option>
                        @foreach (var m in markingLines)
                        {
                            <option value="@m.Id">@m.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Location</label>
                    <select class="form-select form-select-sm" @bind="locationId" disabled="@(locations.Count() <= 1)">
                        <option value="0">— select —</option>
                        @foreach (var l in locations)
                        {
                            <option value="@l.Id">@l.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3" style="margin-top:12px;">
                <label>
                    <input type="checkbox" @bind="confirmSwitch" />
                    I understand this mints real codes on the marking authority and cannot be reverted.
                </label>
                <button class="btn btn-sm btn-primary ms-auto"
                        disabled="@(!CanStart())"
                        @onclick="StartRun">
                    ▶ Start Test Run
                </button>
            </div>
            @if (!string.IsNullOrEmpty(startError))
            {
                <div class="text-danger text-xs" style="margin-top:6px;">@startError</div>
            }
        </div>

        <div>
            <h6 style="margin-top:16px;">Recent runs <span class="text-xs text-muted">(auto-refresh 2 s)</span></h6>
            @if (runs == null)
            {
                <div>Loading…</div>
            }
            else if (runs.Count == 0)
            {
                <div class="text-muted text-xs">No runs yet.</div>
            }
            else
            {
                <table class="table table-sm table-xs-font">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Pack GTIN</th>
                            <th>Bundle GTIN</th>
                            <th>Size</th>
                            <th>User</th>
                            <th>State</th>
                            <th>Record</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in runs)
                        {
                            <tr style="cursor:pointer;" @onclick="() => ToggleExpand(r.Id)">
                                <td>@r.Id @if (r.ClonedFromTestRunId.HasValue)
                                    { <span class="text-xs text-muted">(from #@r.ClonedFromTestRunId @@ @r.ClonedFromStage)</span> }</td>
                                <td>@r.PackGtin</td>
                                <td>@r.BundleGtin</td>
                                <td>@r.PacksPerBundle × @r.BundlesPerContainer</td>
                                <td>@r.User</td>
                                <td><span class="badge @StageBadgeClass(r.Stage)">@r.StageLabel</span></td>
                                <td>@r.RecordDate.ToLocalTime().ToString("dd.MM.yy HH:mm:ss")</td>
                                <td>
                                    @if (r.Stage < 0 && r.Stage != -99)
                                    {
                                        <button class="btn btn-xs btn-outline-warning"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => Reprocess(r.Id, -r.Stage)">↻ Reprocess from stage @(-r.Stage)</button>
                                    }
                                    @if (r.Stage >= 0 && r.Stage < 100)
                                    {
                                        <button class="btn btn-xs btn-outline-danger"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => Cancel(r.Id)">Cancel</button>
                                    }
                                </td>
                            </tr>
                            @if (expandedId == r.Id)
                            {
                                <tr>
                                    <td colspan="8" style="background:#fafafa;">
                                        <div style="padding:8px 16px;">
                                            @if (!string.IsNullOrEmpty(r.StatusMessage))
                                            {
                                                <div class="text-xs" style="margin-bottom:6px;"><strong>Message:</strong> @r.StatusMessage</div>
                                            }
                                            @if (r.MastercaseSscc != null)
                                            {
                                                <div class="text-xs"><strong>Mastercase SSCC:</strong> <code>@r.MastercaseSscc</code></div>
                                            }
                                            @if (r.ApplicationGuid.HasValue)
                                            {
                                                <div class="text-xs"><strong>Application:</strong> <code>@r.ApplicationGuid</code></div>
                                            }
                                            @if (r.AggregationGuid.HasValue)
                                            {
                                                <div class="text-xs"><strong>Aggregation:</strong> <code>@r.AggregationGuid</code></div>
                                            }
                                            <div style="margin-top:8px;">
                                                <strong>Phase log:</strong>
                                                <table class="table table-xs-font" style="margin-top:4px;">
                                                    <thead>
                                                        <tr>
                                                            <th>Stage</th>
                                                            <th>Phase</th>
                                                            <th>Outcome</th>
                                                            <th>Started</th>
                                                            <th>Duration</th>
                                                            <th>Details</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var p in r.PhaseHistory)
                                                        {
                                                            <tr>
                                                                <td>@p.Stage</td>
                                                                <td>@p.PhaseName</td>
                                                                <td><span class="@OutcomeClass(p.Outcome)">@p.Outcome</span></td>
                                                                <td>@p.StartedAt.ToLocalTime().ToString("HH:mm:ss")</td>
                                                                <td>@DurationLabel(p)</td>
                                                                <td>
                                                                    @if (p.ExternalRequestJson != null || p.ExternalResponseJson != null)
                                                                    {
                                                                        var key = $"{r.Id}-{p.Stage}-{p.PhaseName}-{p.StartedAt.Ticks}";
                                                                        <button class="btn btn-xs btn-outline-secondary"
                                                                                @onclick="() => ToggleJson(key)">
                                                                            @(expandedJson == key ? "hide" : "show") JSON
                                                                        </button>
                                                                        @if (expandedJson == key)
                                                                        {
                                                                            @if (p.ExternalRequestJson != null)
                                                                            {
                                                                                <div class="text-xs" style="margin-top:4px;"><strong>req:</strong></div>
                                                                                <pre style="font-size:10px;white-space:pre-wrap;">@p.ExternalRequestJson</pre>
                                                                            }
                                                                            @if (p.ExternalResponseJson != null)
                                                                            {
                                                                                <div class="text-xs"><strong>resp:</strong></div>
                                                                                <pre style="font-size:10px;white-space:pre-wrap;">@p.ExternalResponseJson</pre>
                                                                            }
                                                                        }
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            }
        </div>
    }
</div>

@code {
    private bool isEnabled;
    private TestRunCreateForm form = new() { PacksPerBundle = 2, BundlesPerContainer = 1 };
    private bool confirmSwitch;
    private string? startError;

    private List<Product> packProducts = new();
    private List<Product> bundleProducts = new();
    private IEnumerable<Factory> factories = Array.Empty<Factory>();
    private IEnumerable<MarkingLine> markingLines = Array.Empty<MarkingLine>();
    private IEnumerable<Location> locations = Array.Empty<Location>();
    private int factoryId;
    private int markingLineId;
    private int locationId;

    private List<TestRunDto>? runs;
    private int? expandedId;
    private string? expandedJson;

    private CancellationTokenSource? _cts;
    private bool _active = true;

    protected override async Task OnInitializedAsync()
    {
        isEnabled = Configuration.GetValue<bool>("TestRun:Enabled", true);
        if (!isEnabled) return;

        var allProducts = await ProductService.GetProductsAsync();
        packProducts = allProducts.Where(p => p.Type == 0).ToList();
        bundleProducts = allProducts.Where(p => p.Type == 1).ToList();

        factories = await MetadataService.GetFactoriesAsync();
        markingLines = await MetadataService.GetMarkingLinesAsync();
        locations = await MetadataService.GetLocationsAsync();

        if (factories.Count() == 1) factoryId = factories.First().Id;
        if (markingLines.Count() == 1) markingLineId = markingLines.First().Id;
        if (locations.Count() == 1) locationId = locations.First().Id;

        runs = await TestRunService.ListAsync();
        _cts = new CancellationTokenSource();
        _ = AutoRefreshLoop(_cts.Token);
    }

    public async ValueTask DisposeAsync()
    {
        _active = false;
        _cts?.Cancel();
        _cts?.Dispose();
        await Task.CompletedTask;
    }

    private async Task AutoRefreshLoop(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested && _active)
        {
            try
            {
                await Task.Delay(2000, ct);
                if (ct.IsCancellationRequested || !_active) break;
                if (runs == null || !runs.Any(r => r.Stage >= 0 && r.Stage < 100)) continue;
                var fresh = await TestRunService.ListAsync();
                if (!_active) break;
                runs = fresh;
                await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException) { break; }
            catch (Exception) { }
        }
    }

    private bool CanStart()
    {
        return confirmSwitch
            && form.PackProductId > 0
            && form.BundleProductId > 0
            && form.PacksPerBundle > 0
            && form.BundlesPerContainer > 0
            && factoryId > 0
            && markingLineId > 0
            && locationId > 0
            && !string.IsNullOrWhiteSpace(form.User);
    }

    private async Task StartRun()
    {
        startError = null;
        var f = factories.FirstOrDefault(x => x.Id == factoryId);
        var m = markingLines.FirstOrDefault(x => x.Id == markingLineId);
        var l = locations.FirstOrDefault(x => x.Id == locationId);
        if (f == null || m == null || l == null)
        {
            startError = "Factory / marking line / location not selected.";
            return;
        }
        form.FactoryUuid = f.ExternalUid;
        form.MarkingLineUuid = m.ExternalUid;
        form.LocationUuid = l.ExternalUid;

        var created = await TestRunService.CreateAsync(form);
        if (created == null)
        {
            startError = "API rejected the request. Check logs.";
            return;
        }
        confirmSwitch = false;
        runs = await TestRunService.ListAsync();
        expandedId = created.Id;
    }

    private async Task Reprocess(int parentId, int fromStage)
    {
        var clone = await TestRunService.ReprocessAsync(parentId, fromStage);
        runs = await TestRunService.ListAsync();
        if (clone != null) expandedId = clone.Id;
    }

    private async Task Cancel(int id)
    {
        await TestRunService.CancelAsync(id);
        runs = await TestRunService.ListAsync();
    }

    private void ToggleExpand(int id)
        => expandedId = expandedId == id ? null : id;

    private void ToggleJson(string key)
        => expandedJson = expandedJson == key ? null : key;

    private static string DurationLabel(TestRunPhaseLog p)
    {
        if (!p.FinishedAt.HasValue) return "—";
        var d = p.FinishedAt.Value - p.StartedAt;
        return d.TotalMilliseconds < 1000 ? $"{d.TotalMilliseconds:F0}ms" : $"{d.TotalSeconds:F1}s";
    }

    private static string OutcomeClass(string outcome) => outcome switch
    {
        "OK" => "badge bg-success",
        "FAIL" => "badge bg-danger",
        _ => "badge bg-secondary"
    };

    private static string StageBadgeClass(int stage) => stage switch
    {
        100 => "bg-success",
        -99 => "bg-secondary",
        < 0 => "bg-danger",
        0 => "bg-light text-dark",
        _ => "bg-primary"
    };
}
