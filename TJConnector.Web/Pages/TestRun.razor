@page "/test-run"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.Extensions.Configuration
@using TJConnector.Postgres.Entities
@using TJConnector.SharedLibrary.DTOs.Forms
@using TJConnector.SharedLibrary.Models
@using TJConnector.Web.Services.Implementation
@implements IAsyncDisposable
@inject ITestRunServiceWeb TestRunService
@inject IProductService ProductService
@inject IMetadataService MetadataService
@inject IConfiguration Configuration
@inject HttpClient Http

<PageTitle>Test Run · Abdulla</PageTitle>

<div class="page-root-flex" style="padding:12px;gap:12px;overflow-y:auto;">

    @if (!isEnabled)
    {
        <div class="co-alert co-alert-warning">
            <p><strong>Test Run is disabled</strong> in this environment.
            Set <code>TestRun.Enabled = true</code> in <code>appsettings.json</code> to enable.</p>
        </div>
    }
    else
    {
        @* B7: align with /batches & /containers — use the shared page-header
           pattern so the title strip + auto-refresh pill follow one rule.
           B13: move the auto-refresh hint out of the Recent-runs card title
           and into the page-header pill, matching the other pages. *@
        <div class="co-page-header">
            <h1>Production Contour Test Run</h1>
            <div class="co-actions">
                <span class="co-status @(runs != null && runs.Any(r => r.Stage >= 0 && r.Stage < 100) ? "co-dot-primary" : "co-dot-secondary")"
                      title="Recent-runs auto-refresh every 2 s">
                    <span class="co-dot" aria-hidden="true"></span>
                    Auto-refresh 2 s
                </span>
            </div>
        </div>
        <p class="co-muted" style="margin:0 0 1rem;font-size:0.85rem;">
            Drives the full marking-authority chain (pack → bundle → mastercase → application → aggregation) against the
            real external system. Real codes are minted and cannot be reverted.
        </p>

        <div class="co-card">
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="co-field">
                        <label>Pack GTIN / Product</label>
                        <select class="co-select" @bind="form.PackProductId">
                            <option value="0">— select —</option>
                            @foreach (var p in packProducts)
                            {
                                <option value="@p.Id">@p.Gtin — @p.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="co-field">
                        <label>Bundle GTIN / Product</label>
                        <select class="co-select" @bind="form.BundleProductId">
                            <option value="0">— select —</option>
                            @foreach (var p in bundleProducts)
                            {
                                <option value="@p.Id">@p.Gtin — @p.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="co-field">
                        <label>Packs per bundle</label>
                        <input type="number" min="1" class="co-input" @bind="form.PacksPerBundle" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="co-field">
                        <label>Bundles per container</label>
                        <input type="number" min="1" class="co-input" @bind="form.BundlesPerContainer" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="co-field">
                        <label>User</label>
                        <input class="co-input" @bind="form.User" />
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="co-field">
                        <label>Factory</label>
                        <select class="co-select" @bind="factoryId" disabled="@(factories.Count() <= 1)">
                            <option value="0">— select —</option>
                            @foreach (var f in factories)
                            {
                                <option value="@f.Id">@f.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="co-field">
                        <label>Marking line</label>
                        <select class="co-select" @bind="markingLineId" disabled="@(markingLines.Count() <= 1)">
                            <option value="0">— select —</option>
                            @foreach (var m in markingLines)
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="co-field">
                        <label>Location</label>
                        <select class="co-select" @bind="locationId" disabled="@(locations.Count() <= 1)">
                            <option value="0">— select —</option>
                            @foreach (var l in locations)
                            {
                                <option value="@l.Id">@l.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3" style="margin-top:12px;">
                <label class="co-checkbox">
                    <input type="checkbox" @bind="confirmSwitch" />
                    I understand this mints real codes on the marking authority and cannot be reverted.
                </label>
                <button class="co-btn co-btn-primary ms-auto"
                        disabled="@(!CanStart())"
                        @onclick="StartRun">
                    Start Test Run
                </button>
            </div>
            @if (!string.IsNullOrEmpty(startError))
            {
                <div class="co-alert co-alert-error" style="margin-top:8px;"><p>@startError</p></div>
            }
        </div>

        <div class="co-card" style="margin-top:16px;">
            <div class="co-section-header"><h2>Recent runs</h2></div>
            @if (runs == null)
            {
                <div class="co-state"><p class="co-state-title">Loading…</p></div>
            }
            else if (runs.Count == 0)
            {
                <div class="co-state"><p class="co-state-title">No runs yet.</p></div>
            }
            else
            {
                <table class="co-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Pack GTIN</th>
                            <th>Bundle GTIN</th>
                            <th>Size</th>
                            <th>User</th>
                            <th>State</th>
                            <th>Record</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in runs)
                        {
                            <tr class="co-row-clickable" @onclick="() => ToggleExpand(r.Id)">
                                <td class="co-mono">@r.Id @if (r.ClonedFromTestRunId.HasValue)
                                    { <span class="co-faint">(from #@r.ClonedFromTestRunId @@ @r.ClonedFromStage)</span> }</td>
                                <td class="co-mono">@r.PackGtin</td>
                                <td class="co-mono">@r.BundleGtin</td>
                                <td>@r.PacksPerBundle × @r.BundlesPerContainer</td>
                                <td>@r.User</td>
                                <td>
                                    <span class="co-status @StageDotClass(r.Stage)">
                                        <span class="co-dot"></span>@r.StageLabel
                                    </span>
                                </td>
                                <td>@r.RecordDate.ToLocalTime().ToString("dd.MM.yy HH:mm")</td>
                                <td>
                                    @if (r.Stage < 0 && r.Stage != -99)
                                    {
                                        <button class="co-btn co-btn-default co-btn-sm"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => Reprocess(r.Id, -r.Stage)">Reprocess from stage @(-r.Stage)</button>
                                    }
                                    @if (r.Stage >= 0 && r.Stage < 100)
                                    {
                                        <button class="co-btn co-btn-danger co-btn-sm"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => Cancel(r.Id)">Cancel</button>
                                    }
                                </td>
                            </tr>
                            @if (expandedId == r.Id)
                            {
                                <tr class="co-detail-row">
                                    <td colspan="8">
                                        <div>
                                            @if (!string.IsNullOrEmpty(r.StatusMessage))
                                            {
                                                <div style="margin-bottom:6px;font-size:0.8rem;"><strong>Message:</strong> @r.StatusMessage</div>
                                            }
                                            @if (r.MastercaseSscc != null)
                                            {
                                                <div style="font-size:0.8rem;"><strong>Mastercase SSCC:</strong> <span class="co-mono">@r.MastercaseSscc</span></div>
                                            }
                                            @if (r.ApplicationGuid.HasValue)
                                            {
                                                <div style="font-size:0.8rem;"><strong>Application:</strong> <span class="co-mono">@r.ApplicationGuid</span></div>
                                            }
                                            @if (r.AggregationGuid.HasValue)
                                            {
                                                <div style="font-size:0.8rem;"><strong>Aggregation:</strong> <span class="co-mono">@r.AggregationGuid</span></div>
                                            }
                                            <div style="margin-top:8px;">
                                                <div class="co-eyebrow" style="margin-bottom:4px;">Phase log</div>
                                                <table class="co-table co-table-nested">
                                                    <thead>
                                                        <tr>
                                                            <th>Stage</th>
                                                            <th>Phase</th>
                                                            <th>Outcome</th>
                                                            <th>Started</th>
                                                            <th>Duration</th>
                                                            <th>Details</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var p in r.PhaseHistory)
                                                        {
                                                            <tr>
                                                                <td>@p.Stage</td>
                                                                <td>@p.PhaseName</td>
                                                                <td>
                                                                    <span class="co-status @OutcomeDotClass(p.Outcome)">
                                                                        <span class="co-dot"></span>@p.Outcome
                                                                    </span>
                                                                </td>
                                                                <td>@p.StartedAt.ToLocalTime().ToString("HH:mm:ss")</td>
                                                                <td>@DurationLabel(p)</td>
                                                                <td>
                                                                    @if (p.ExternalRequestJson != null || p.ExternalResponseJson != null)
                                                                    {
                                                                        var key = $"{r.Id}-{p.Stage}-{p.PhaseName}-{p.StartedAt.Ticks}";
                                                                        <button class="co-btn co-btn-ghost co-btn-sm"
                                                                                @onclick="() => ToggleJson(key)">
                                                                            @(expandedJson == key ? "hide" : "show") JSON
                                                                        </button>
                                                                        @if (expandedJson == key)
                                                                        {
                                                                            @if (p.ExternalRequestJson != null)
                                                                            {
                                                                                <div style="margin-top:4px;font-size:0.8rem;"><strong>req:</strong></div>
                                                                                <pre class="co-codeblock">@p.ExternalRequestJson</pre>
                                                                            }
                                                                            @if (p.ExternalResponseJson != null)
                                                                            {
                                                                                <div style="font-size:0.8rem;"><strong>resp:</strong></div>
                                                                                <pre class="co-codeblock">@p.ExternalResponseJson</pre>
                                                                            }
                                                                        }
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- ── External DB Test ────────────────────────────────── -->
        <div class="co-card" style="margin-top:16px;">
            <div class="co-section-header"><h2>External Database Connection Test</h2></div>
            <div class="co-muted" style="margin-bottom:8px;font-size:0.8rem;">
                Test SQL Server connection by querying container hierarchy. The MC number does not need to be valid for this market — the query will execute and return whatever the external DB has (or an error if the connection fails).
            </div>
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="co-field">
                        <label>Mastercase Number</label>
                        <input class="co-input" placeholder="Enter MC number…" @bind="dbTestMcNumber" />
                    </div>
                </div>
                <div class="col-md-6 d-flex align-items-end gap-2">
                    <button class="co-btn co-btn-default"
                            disabled="@(string.IsNullOrWhiteSpace(dbTestMcNumber) || dbTestRunning)"
                            @onclick="RunDbTestContent">
                        @(dbTestRunning ? "Testing…" : "Test Content Query")
                    </button>
                    <button class="co-btn co-btn-default"
                            disabled="@(string.IsNullOrWhiteSpace(dbTestMcNumber) || dbTestRunning)"
                            @onclick="RunDbTestInfo">
                        @(dbTestRunning ? "Testing…" : "Test Info Query")
                    </button>
                </div>
            </div>
            @if (dbTestResult != null)
            {
                <div class="mt-2">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <strong style="font-size:0.82rem;">@dbTestLabel</strong>
                        <span class="co-status @(dbTestSuccess ? "co-dot-success" : "co-dot-danger")">
                            <span class="co-dot"></span>@(dbTestSuccess ? "OK" : "Failed")
                        </span>
                        @if (dbTestDurationMs.HasValue)
                        {
                            <span class="co-muted co-tnum" style="font-size:0.78rem;">@(dbTestDurationMs)ms</span>
                        }
                    </div>
                    <pre class="co-codeblock" style="max-height:300px;">@dbTestResult</pre>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool isEnabled;
    private TestRunCreateForm form = new() { PacksPerBundle = 2, BundlesPerContainer = 1 };
    private bool confirmSwitch;
    private string? startError;

    private List<Product> packProducts = new();
    private List<Product> bundleProducts = new();
    private IEnumerable<Factory> factories = Array.Empty<Factory>();
    private IEnumerable<MarkingLine> markingLines = Array.Empty<MarkingLine>();
    private IEnumerable<Location> locations = Array.Empty<Location>();
    private int factoryId;
    private int markingLineId;
    private int locationId;

    private List<TestRunDto>? runs;
    private int? expandedId;
    private string? expandedJson;

    private CancellationTokenSource? _cts;
    private bool _active = true;

    protected override async Task OnInitializedAsync()
    {
        isEnabled = Configuration.GetValue<bool>("TestRun:Enabled", true);
        if (!isEnabled) return;

        var allProducts = await ProductService.GetProductsAsync();
        packProducts = allProducts.Where(p => p.Type == 0).ToList();
        bundleProducts = allProducts.Where(p => p.Type == 1).ToList();

        factories = await MetadataService.GetFactoriesAsync();
        markingLines = await MetadataService.GetMarkingLinesAsync();
        locations = await MetadataService.GetLocationsAsync();

        if (factories.Count() == 1) factoryId = factories.First().Id;
        if (markingLines.Count() == 1) markingLineId = markingLines.First().Id;
        if (locations.Count() == 1) locationId = locations.First().Id;

        runs = await TestRunService.ListAsync();
        _cts = new CancellationTokenSource();
        _ = AutoRefreshLoop(_cts.Token);
    }

    public async ValueTask DisposeAsync()
    {
        _active = false;
        _cts?.Cancel();
        _cts?.Dispose();
        await Task.CompletedTask;
    }

    private async Task AutoRefreshLoop(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested && _active)
        {
            try
            {
                await Task.Delay(2000, ct);
                if (ct.IsCancellationRequested || !_active) break;
                if (runs == null || !runs.Any(r => r.Stage >= 0 && r.Stage < 100)) continue;
                var fresh = await TestRunService.ListAsync();
                if (!_active) break;
                runs = fresh;
                await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException) { break; }
            catch (Exception) { }
        }
    }

    private bool CanStart()
    {
        return confirmSwitch
            && form.PackProductId > 0
            && form.BundleProductId > 0
            && form.PacksPerBundle > 0
            && form.BundlesPerContainer > 0
            && factoryId > 0
            && markingLineId > 0
            && locationId > 0
            && !string.IsNullOrWhiteSpace(form.User);
    }

    private async Task StartRun()
    {
        startError = null;
        var f = factories.FirstOrDefault(x => x.Id == factoryId);
        var m = markingLines.FirstOrDefault(x => x.Id == markingLineId);
        var l = locations.FirstOrDefault(x => x.Id == locationId);
        if (f == null || m == null || l == null)
        {
            startError = "Factory / marking line / location not selected.";
            return;
        }
        form.FactoryUuid = f.ExternalUid;
        form.MarkingLineUuid = m.ExternalUid;
        form.LocationUuid = l.ExternalUid;

        var created = await TestRunService.CreateAsync(form);
        if (created == null)
        {
            startError = "API rejected the request. Check logs.";
            return;
        }
        confirmSwitch = false;
        runs = await TestRunService.ListAsync();
        expandedId = created.Id;
    }

    private async Task Reprocess(int parentId, int fromStage)
    {
        var clone = await TestRunService.ReprocessAsync(parentId, fromStage);
        runs = await TestRunService.ListAsync();
        if (clone != null) expandedId = clone.Id;
    }

    private async Task Cancel(int id)
    {
        await TestRunService.CancelAsync(id);
        runs = await TestRunService.ListAsync();
    }

    private void ToggleExpand(int id)
        => expandedId = expandedId == id ? null : id;

    private void ToggleJson(string key)
        => expandedJson = expandedJson == key ? null : key;

    private static string DurationLabel(TestRunPhaseLog p)
    {
        if (!p.FinishedAt.HasValue) return "—";
        var d = p.FinishedAt.Value - p.StartedAt;
        return d.TotalMilliseconds < 1000 ? $"{d.TotalMilliseconds:F0}ms" : $"{d.TotalSeconds:F1}s";
    }

    private static string OutcomeClass(string outcome) => outcome switch
    {
        "OK" => "badge bg-success",
        "FAIL" => "badge bg-danger",
        _ => "badge bg-secondary"
    };

    // CalmOps status tone (dot colour) — the dot carries the colour, label stays slate.
    private static string OutcomeDotClass(string outcome) => outcome switch
    {
        "OK" => "co-dot-success",
        "FAIL" => "co-dot-danger",
        _ => "co-dot-secondary"
    };

    private static string StageDotClass(int stage)
    {
        if (stage == 100) return "co-dot-success";   // Completed
        if (stage == -99) return "co-dot-secondary"; // Canceled
        if (stage < 0)    return "co-dot-danger";    // Failed at stage
        if (stage == 0)   return "co-dot-info";      // Created / queued
        return "co-dot-primary";                     // Running
    }

    // if/else (not a switch with relational patterns) — Razor parser in older
    // SDKs chokes on `< 0` inside @code blocks.
    private static string StageBadgeClass(int stage)
    {
        if (stage == 100) return "bg-success";
        if (stage == -99) return "bg-secondary";
        if (stage < 0)    return "bg-danger";
        if (stage == 0)   return "bg-light text-dark";
        return "bg-primary";
    }

    // ── External DB Test ─────────────────────────────────────────────────
    private string dbTestMcNumber = string.Empty;
    private bool dbTestRunning;
    private string? dbTestResult;
    private string? dbTestLabel;
    private bool dbTestSuccess;
    private long? dbTestDurationMs;

    private async Task RunDbTestContent()
    {
        await RunDbTest("Content Query", async () =>
        {
            var resp = await Http.GetAsync($"api/mccontent/{Uri.EscapeDataString(dbTestMcNumber.Trim())}");
            return await resp.Content.ReadAsStringAsync();
        });
    }

    private async Task RunDbTestInfo()
    {
        await RunDbTest("Info Query", async () =>
        {
            var resp = await Http.PostAsJsonAsync("api/mcinfo", new[] { dbTestMcNumber.Trim() });
            return await resp.Content.ReadAsStringAsync();
        });
    }

    private async Task RunDbTest(string label, Func<Task<string>> action)
    {
        dbTestRunning = true;
        dbTestLabel = label;
        dbTestResult = null;
        dbTestSuccess = false;
        dbTestDurationMs = null;

        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            var result = await action();
            sw.Stop();
            dbTestDurationMs = sw.ElapsedMilliseconds;
            dbTestResult = result;
            dbTestSuccess = true;
        }
        catch (Exception ex)
        {
            sw.Stop();
            dbTestDurationMs = sw.ElapsedMilliseconds;
            dbTestResult = ex.Message;
            dbTestSuccess = false;
        }
        finally
        {
            dbTestRunning = false;
        }
    }
}
